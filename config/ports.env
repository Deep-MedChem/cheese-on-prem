# ─────────────────────────────────────────────────────────────────────────────
# CHEESE on-prem port map  —  the single place to see/change ports.
#
# scripts/_compose-env sources this on every `cheese start*`, so the values feed
# both docker-compose interpolation AND the start scripts' auto-port-bumping.
# docker-compose.yml keeps matching `${VAR:-default}` fallbacks, so it still runs
# standalone if this file is absent.
#
# Two kinds of ports live here — keep the distinction in mind:
#
#   *_HOST_PORT       Port published on the HOST machine. Safe to change to dodge
#                     collisions. The start scripts also auto-bump these to the
#                     next free port at launch if the chosen one is busy.
#
#   *_INTERNAL_PORT   Port a service listens on INSIDE its container. Baked into
#                     the image — only change if the image itself changes. Used
#                     by healthchecks and by service-to-service URLs.
#
# Precedence: a value already set in your shell environment wins over this file
# (that's how the runtime auto-bump overrides a HOST port). This file wins over
# the compose defaults.
# ─────────────────────────────────────────────────────────────────────────────

# ── Host-published ports (change freely) ─────────────────────────────────────
API_HOST_PORT=8001            # cheese-api          — public CHEESE API
UI_HOST_PORT=3001             # cheese-ui           — web UI
JOBS_FILE_SERVER_PORT=8000    # cheese-file-server  — job-result downloads
INFERENCE_HOST_PORT=8005      # cheese-inference    — electrostatics inference
ALIGNMENT_HOST_PORT=8006      # cheese-alignment    — conformer alignment

# ── Internal container ports (match the images) ──────────────────────────────
DB_INTERNAL_PORT=8001         # cheese-db / cheese-jobs-db listen port
API_INTERNAL_PORT=8001        # cheese-api listen port
UI_INTERNAL_PORT=3001         # cheese-ui listen port
FILE_SERVER_INTERNAL_PORT=8000
INFERENCE_INTERNAL_PORT=8000
ALIGNMENT_INTERNAL_PORT=8001  # cheese-alignment-service: uvicorn app.main:app --port 8001
