# cheese — "headless" overlay.
#
# Strips the search-ui frontend, user auth, and Supabase from the install.
# Layer this on top of values-onprem.yaml + values-secrets.yaml:
#
#   helm install cheese cheese-k8s/charts/cheese \
#     --namespace cheese \
#     -f cheese-k8s/charts/cheese/values-onprem.yaml \
#     -f cheese-k8s/charts/cheese/values-secrets.yaml \
#     -f cheese-k8s/charts/cheese/values-headless.yaml
#
# End state: cheese-database (4 roles), cheese-synthongpt, and
# cheese-orchestrator only. The orchestrator API is reachable at
# http://cheese-api.localtest.me (single ingress kept; no auth in front).
# Stripe is not part of this chart, so there is nothing to disable for it.

searchUi:
  enabled: false

orchestrator:
  supabase:
    enable: "false"
    url: ""
  env:
    enable_auth: "false"
    enable_notifications: "false"
  ingress:
    # Keep the API ingress so the orchestrator stays reachable from the host.
    # Disable it if you only want in-cluster access; reach the API with
    #   kubectl port-forward -n cheese svc/cheese-orchestrator 8001:80
    public:
      enabled: true
    private:
      enabled: false
