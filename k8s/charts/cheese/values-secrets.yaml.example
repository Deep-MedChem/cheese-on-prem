# cheese — secret values (inline / self-contained path).
#
# Copy to values-secrets.yaml (gitignored) and fill in, then pass at install:
#   helm install cheese charts/cheese -n cheese -f my-values.yaml -f values-secrets.yaml
#
# EXTERNAL SECRETS: to manage secrets yourself (Vault / External Secrets Operator /
# SealedSecrets / a pre-created `kubectl create secret`), set
# `<component>.secret.existingSecret: <name>` in your values instead of filling
# these in. The chart then renders NO inline Secret and references yours by name.
# Required keys per component (so an externally-managed Secret is a drop-in):
#   cheese-database         : production, cheeseLicense, discordWebhookUrl
#   cheese-orchestrator     : supabaseServiceRoleKey, discordWebhookUrl
#   cheese-search-ui-secret : CHEESE_UI_USER_SECRET, SUPABASE_ANON_KEY,
#                             SUPABASE_SERVICE_ROLE_KEY, VITE_SUPABASE_ANON_KEY,
#                             DISCORD_WEBHOOK_URL
#   cheese-supabase         : postgresPassword, jwtSecret, anonKey, serviceRoleKey

# --- cheese-database -------------------------------------------------------
database:
  secret:
    # existingSecret: my-db-secret          # uncomment to use an external Secret
    production: "REPLACE_ME"                 # OUR_SECRET-style value
    cheeseLicense: ""                        # optional inline license
    cheeseLicenseFile: "cheese_license_file.json"  # filename on the PVC, relative to /data
    discordWebhookUrl: ""

# --- cheese-orchestrator ---------------------------------------------------
orchestrator:
  supabase:
    serviceRoleKey: "REPLACE_ME"             # external-Supabase service role key (ignored if you run in-cluster supabase)
  secret:
    # existingSecret: my-orch-secret
    discordWebhookUrl: ""
    cheeseLicenseFile: "cheese_license_file.json"  # must match database.secret.cheeseLicenseFile
  env:
    production: "REPLACE_ME"                 # must match database.secret.production

# --- cheese-search-ui ------------------------------------------------------
searchUi:
  secret:
    # existingSecret: my-ui-secret
    cheeseUiUserSecret: "REPLACE_ME"
    supabaseAnonKey: "REPLACE_ME"            # match supabase.secret.anonKey when running in-cluster supabase
    supabaseServiceRoleKey: "REPLACE_ME"
    viteSupabaseAnonKey: "REPLACE_ME"
    discordWebhookUrl: ""

# --- supabase (only when supabase.enabled=true; in-cluster auth) ------------
supabase:
  secret:
    # existingSecret: my-supabase-secret
    postgresPassword: "REPLACE_ME"           # strong password; also becomes the authenticator role password
    jwtSecret: "REPLACE_ME"                  # shared HS256 secret (GoTrue + PostgREST + UI)
    anonKey: "REPLACE_ME"                    # anon JWT signed with jwtSecret
    serviceRoleKey: "REPLACE_ME"             # service_role JWT signed with jwtSecret
