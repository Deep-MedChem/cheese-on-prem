# cheese — site overrides (non-secret).
#
# Copy to values-onprem.yaml (gitignored) and edit. Anything not set here falls
# back to charts/cheese/values.yaml.
#
#   helm install cheese cheese-k8s/charts/cheese \
#     --namespace cheese \
#     -f cheese-k8s/charts/cheese/values-onprem.yaml \
#     -f cheese-k8s/charts/cheese/values-secrets.yaml

# --- Shared data plane (mounted by database/orchestrator/synthongpt) -------
data:
  pvcName: cheese-data-pvc
  mountPath: /data

# --- cheese-database -------------------------------------------------------
database:
  enabled: true
  image:
    source: acr                            # local | acr
    local:
      repository: cheese-database-local
      tag: dev
    acr:
      repository: cheese.azurecr.io/on-prem/cheese-database/cheese-customer
      tag: latest
      pullSecret: cheese-acr-pull
  databases:
    test:
      enabled: true
      output_directory: "test_database"
      index_type: "Flat"
      delimiter: ","
    # enamine_real_diverse:
    #   enabled: true
    #   output_directory: "enamine_real_diverse"
    #   index_type: "IVF"
    #   delimiter: " "

# --- cheese-synthongpt -----------------------------------------------------
synthongpt:
  enabled: true
  image:
    source: acr
    local:
      repository: cheese-synthongpt-local
      tag: dev
    acr:
      repository: cheese.azurecr.io/on-prem/cheese-synthongpt/cheese-customer
      tag: latest
      pullSecret: cheese-acr-pull
  runtime:
    device: "cpu"                          # "cpu" | "cuda"
    seed: 0
    extraArgs: []

# --- cheese-orchestrator ---------------------------------------------------
orchestrator:
  enabled: true
  image:
    source: acr
    local:
      repository: cheese-orchestrator-local
      tag: dev
    acr:
      repository: cheese.azurecr.io/on-prem/cheese-orchestrator/cheese-customer
      tag: latest
      pullSecret: cheese-acr-pull
  supabase:
    enable: "true"
    url: "https://your-project.supabase.co"
  env:
    domain_url: "http://cheese-api.localtest.me"
    ui_url: "http://cheese-ui.localtest.me"
    cheese_env: "onprem"
    enable_auth: "false"
    enable_notifications: "false"
    db_url: "http://cheese-database-app.cheese.svc.cluster.local:8001"
    jobs_db_url: "http://cheese-database-jobs-db.cheese.svc.cluster.local:8001"
    synthongpt_url: "http://cheese-synthongpt.cheese.svc.cluster.local:8000"
    synthongpt_api_timeout_seconds: "180"
    synthongpt_max_products: "10000"
  ingress:
    public:
      enabled: true
      className: nginx
      annotations:
        nginx.ingress.kubernetes.io/proxy-read-timeout: "300"
      hosts:
        - host: cheese-api.localtest.me
          paths:
            - path: /
              pathType: Prefix
      tls: []
    private:
      enabled: false

# --- cheese-search-ui ------------------------------------------------------
searchUi:
  enabled: true
  image:
    source: acr
    local:
      repository: cheese-search-ui-local
      tag: dev
    acr:
      repository: cheese.azurecr.io/on-prem/cheese-search-ui/cheese-customer
      tag: latest
      pullSecret: cheese-acr-pull
  config:
    LOCAL: "True"
    NODE_ENV: "production"
    HOST: "0.0.0.0"
    PORT: "3001"
    FRONTEND_URL: "http://cheese-ui.localtest.me"
    CHEESE_API: "http://cheese-orchestrator.cheese.svc.cluster.local"
    SUPABASE_URL: "https://your-project.supabase.co"
    VITE_SUPABASE_URL: "https://your-project.supabase.co"
    VITE_CDN_ENABLED: "false"
    VITE_CDN_BASE_URL: ""
  ingress:
    enabled: true
    className: nginx
    hosts:
      - host: cheese-ui.localtest.me
        paths:
          - path: /
            pathType: Prefix
    tls: []
