IMAGE_NAME=cheese-search-ui-local
IMAGE_TAG=dev

# Build-time variables for Vite.
# These are baked into the frontend bundle at `pnpm run build` time and cannot
# be changed at runtime via the chart's configmap — the values below replace
# `import.meta.env.VITE_*` constants in the compiled JS the browser downloads.
#
# TODO(after upstream UI refactor): cheese-search-ui is migrating these from
# Vite (browser) constants to runtime env on the SSR layer. Once that lands,
# move the ENABLE_* and CDN_* flags below to the chart's `config:` block in
# values-onprem.yaml and drop them from this file.

LOCAL=True
CDN_BASE_URL=
CDN_ENABLED=false
SUPABASE_URL="THE SUPABASE URL (https://abcdefg.supabase.co)"
SUPABASE_ANON_KEY="THE SUPABASE KEY"

# On-prem feature gates. Defaults below are the on-prem-correct settings —
# Dockerfile defaults disagree on STRIPE/NOTIFICATIONS, so leaving these unset
# would silently bake in the wrong values.
ENABLE_ANALYTICS=false
ENABLE_AUTH=true
ENABLE_TRACKING=true
ENABLE_STRIPE=false
ENABLE_NOTIFICATIONS=false
