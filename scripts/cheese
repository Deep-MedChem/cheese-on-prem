#!/bin/bash


# Function to display usage
show_help() {
  echo "Welcome to CHEESE !"
  echo "Usage: cheese [options]"
  echo "Commands:"
  echo "  configure-engine             Edit the CHEESE engine config (cheese_config_file.yaml)"
  echo "  generate-license-key         Generate CHEESE license key"
  echo "  start-server                 Run CHEESE server (API)"
  echo "  start-inference              Run CHEESE electrostatics inference service (optional)"
  echo "  start-alignment              Run CHEESE conformer alignment service (optional)"
  echo "  stop-servers                 Stop all CHEESE servers"
  echo "  stop-apps                    Stop all CHEESE UIs"
  echo "  start-app                    Run CHEESE UI"
  echo "  start                        Run CHEESE server + UI (+ inference + alignment)"
  echo "  embeddings-cpu               Run CHEESE Embeddings computation on CPU"
  echo "  search                       Run CHEESE Search"
  echo "  visualize                    Run CHEESE Embeddings visualization"
  echo "  run-inference                Run CHEESE indexing"
  echo "  explorer                     Run CHEESE Explorer"
  echo "  update-scripts               Update CHEESE scripts"
  echo "  update-env                   Update CHEESE environment file"
  echo "  update-images                Update CHEESE Docker Images"
  echo "  update-license               Update CHEESE license file"
  echo "  check-license               Check CHEESE license"
  echo "  configure-dbs                Choose which indexed databases to download"
  echo "  download-dbs                 Download CHEESE indexed databases"
  echo "  preflight-config             Validate & auto-heal the engine config (run before start)"
  echo "  doctor                       Diagnose stack/config problems and suggest fixes"
  echo "  -h, --help                   Show this help message"
  exit 1
}

# Check if no arguments are passed
if [ $# -eq 0 ]; then
    # Show help if no arguments
    show_help
    exit 0
fi


source ${HOME}/.config/cheese/cheese-env.sh



# Parse command-line arguments manually
while [[ $# -gt 0 ]]; do
  case "$1" in
    update-images)
      shift 1
      update-images $@
      exit 0
      ;;
    update-scripts)
      shift 1
      update-scripts $@
      exit 0
      ;;
    update-license)
      shift 1
      update-license $@
      exit 0
      ;;
    check-license)
      shift 1
      check-license $@
      ;;
    configure-engine)
      shift 1
      configure-engine $@
      exit 0
      ;;
    configure-nginx)
      shift 1
      configure-nginx $@
      exit 0
      ;;
    configure-oauth2)
      shift 1
      configure-oauth2 $@
      exit 0
      ;;
    update-env)
      shift 1
      update-env $@
      exit 0
      ;;
    start-server)
      shift 1
      set -e
      check-license
      start-server $@
      exit 0
      ;;
    start-inference)
      shift 1
      set -e
      check-license
      start-inference $@
      exit 0
      ;;
    start-alignment)
      shift 1
      set -e
      check-license
      start-alignment $@
      exit 0
      ;;
    stop-servers)
      shift 1
      stop-servers $@
      exit 0
      ;;
    stop-apps)
      shift 1
      stop-apps $@
      exit 0
      ;;
    stop)
      shift 1
      stop-main-servers $@
      exit 0
      ;;
    start-app)
      shift 1
      set -e
      check-license
      start-app $@
      exit 0
      ;;
    start)
      shift 1
      set -e
      check-license
      start_args=("$@")
      api_port=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          -p|--port)
            api_port="$2"
            shift 2
            ;;
          *)
            shift 1
            ;;
        esac
      done
      # Core first: db + API (blocks until the API is healthy), then the UI — so
      # the UI is usable as soon as the core is up. The UI only depends_on `api`
      # (compose: condition service_healthy), not on the optional services below.
      start-server "${start_args[@]}"
      if [ -n "$api_port" ]; then
        start-app --api_port "$api_port"
      else
        start-app
      fi

      # ESP-charge (inference) and conformer-alignment are OPTIONAL and slow to
      # boot (alignment can take minutes). The UI proxies to them per-request and
      # returns a graceful 503 while they're down (src/server.ts), so blocking the
      # whole start on their health-waits just delays a usable UI for no reason.
      # Bring them up in the BACKGROUND instead: the features light up on their
      # own once the containers answer — no UI restart needed, because the UI
      # talks to a fixed container alias resolved by Docker DNS at request time.
      mkdir -p "${HOME}/.cache/cheese"
      echo "UI is up. ESP-charge + alignment services are starting in the background"
      echo "(logs: ${HOME}/.cache/cheese/{inference,alignment}.log); those features"
      echo "appear automatically once ready — no restart needed."
      ( start-inference >>"${HOME}/.cache/cheese/inference.log" 2>&1 \
          || echo "(inference service failed to start; ESP charge feature will be hidden)" ) &
      ( start-alignment >>"${HOME}/.cache/cheese/alignment.log" 2>&1 \
          || echo "(alignment service failed to start; conformer alignment feature will be hidden)" ) &

      if [ "$NGINX" = "true" ] ; then
      start-oauth2
      start-nginx
      echo "CHEESE is running here : https://$IP/"
      fi
      exit 0
      ;;
    run-inference)
      shift 1
      set -e
      check-license
      run-inference $@
      exit 0
      ;;
    embeddings-cpu)
      shift 1
      set -e
      check-license
      embeddings-cpu $@
      exit 0
      ;;
    search)
      shift 1
      set -e
      check-license
      search $@
      exit 0
      ;;
    visualize)
      shift 1
      set -e
      check-license
      visualize $@
      exit 0
      ;;
    generate-license-key)
      shift 1
      generate-license-key $@
      exit 0
      ;;
    explorer)
      shift 1
      set -e
      check-license
      explorer $@
      exit 0
      ;;
    configure-dbs)
      shift 1
      configure-dbs $@
      exit 0
      ;;
    download-dbs)
      shift 1
      download-dbs $@
      exit 0
      ;;
    preflight-config)
      shift 1
      preflight-config $@
      exit 0
      ;;
    doctor)
      shift 1
      doctor $@
      exit 0
      ;;
    uninstall)
      shift 1
      uninstall-cheese $@
      exit 0
      ;;
    -h|--help)
      show_help
      ;;
    *)
      echo "Unknown command: $1"
      exit 1
      show_help
      ;;
  esac
done
