#!/bin/bash
# Bring up NGINX (perimeter TLS + auth routing). Requires the `sso` profile,
# which the cheese wrapper sets automatically when NGINX=true. If invoked
# directly, force the profile here.

set -e
source "$(dirname "$(readlink -f "$0")")/_compose-env"

export COMPOSE_PROFILES="sso"

echo "Starting NGINX (sso profile)..."
$COMPOSE_CMD --profile sso up -d nginx
echo "NGINX is up on :80 and :443."
