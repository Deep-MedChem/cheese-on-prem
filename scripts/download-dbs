#!/bin/bash
# Download indexed databases from the SFTP server using rclone (resumable and
# incremental — re-running only fetches what's missing/changed). Databases on
# the server are plain folders, so there's no archive extraction step.
#
# Selection: if ${DB_CONFIG} exists (written by `cheese configure-dbs`), only
# the databases flagged =yes are downloaded. With no config, ALL available
# databases are downloaded by default.
set -e
source "$(dirname "$(readlink -f "$0")")/_db-common"

show_help() {
  echo "Usage: cheese download-dbs --dest <folder> [options]"
  echo "Options:"
  echo "  --dest FOLDER        Destination folder for the databases (required)"
  echo "  --transfers N        Parallel file transfers (default: 4)"
  echo "  -h, --help           Show this help message"
  echo
  echo "Run 'cheese configure-dbs' first to choose which databases to download;"
  echo "without a selection config, all available databases are downloaded."
  exit 1
}

convert_to_absolute_path() {
  case "$1" in /*) echo "$1" ;; *) echo "$(pwd)/$1" ;; esac
}

# Engine config that maps each database to its on-disk folder (OUTPUT_DIRECTORIES).
# CONFIG_FILE is exported by cheese-env.sh; fall back to the standard location.
ENGINE_CONFIG="${CONFIG_FILE:-${HOME}/.config/cheese/cheese_config_file.yaml}"

# Add/update one `  <key>: '<path>'` entry under OUTPUT_DIRECTORIES so the engine
# finds the database without the operator hand-editing the YAML. The install
# writes OUTPUT_DIRECTORIES as the last section, so appending lands under it;
# existing keys are updated in place (indentation preserved).
register_output_dir() {
  local key="$1" path="$2" cfg="$3" key_re
  [ -f "$cfg" ] || { echo "  (engine config $cfg not found — skipping OUTPUT_DIRECTORIES update)"; return 0; }
  grep -qE '^OUTPUT_DIRECTORIES:' "$cfg" || printf 'OUTPUT_DIRECTORIES:\n' >> "$cfg"
  key_re=$(printf '%s' "$key" | sed 's/[][\.*^$+?(){}|/]/\\&/g')
  if grep -qE "^[[:space:]]+${key_re}:" "$cfg"; then
    sed -E "s|^([[:space:]]+)${key_re}:.*|\1${key}: '${path}'|" "$cfg" > "$cfg.tmp" && mv "$cfg.tmp" "$cfg"
  else
    printf "  %s: '%s'\n" "$key" "$path" >> "$cfg"
  fi
}

dest=""
transfers=4
while [[ $# -gt 0 ]]; do
  case "$1" in
    --dest)
      [ -z "$2" ] && { echo "No destination folder specified (use --dest)."; exit 1; }
      dest=$(convert_to_absolute_path "$2"); shift 2 ;;
    --transfers)
      [ -z "$2" ] && { echo "--transfers needs a number."; exit 1; }
      transfers="$2"; shift 2 ;;
    -h|--help) show_help ;;
    *) echo "Unknown option: $1"; show_help ;;
  esac
done

[ -z "$dest" ] && { echo "Destination folder is required (use --dest)."; show_help; }

# Verify we can actually reach the server with the configured credentials, and
# fail fast with a targeted message if not.
db_ping || exit 1

# Build the list of databases to download.
selected=()
if [ -f "$DB_CONFIG" ]; then
  echo "Using selection from $DB_CONFIG"
  while IFS= read -r line; do
    line="${line%%#*}"
    [[ "$line" =~ ^[[:space:]]*$ ]] && continue
    name="${line%%=*}"; name="${name//[[:space:]]/}"
    flag="${line#*=}";  flag="${flag//[[:space:]]/}"
    [ -n "$name" ] && [ "$flag" = "yes" ] && selected+=("$name")
  done < "$DB_CONFIG"
  if [ "${#selected[@]}" -eq 0 ]; then
    echo "No databases are flagged =yes in $DB_CONFIG — nothing to download."
    echo "Edit it (or run 'cheese configure-dbs') to select databases."
    exit 0
  fi
else
  echo "No selection config found — downloading ALL available databases."
  echo "(Run 'cheese configure-dbs' first if you want to pick a subset.)"
  listing=$(list_db_dirs) || exit 1
  [ -z "$listing" ] && { echo "No databases found on ${DB_SERVER}." >&2; exit 1; }
  mapfile -t selected <<< "$listing"
fi

mkdir -p "$dest"
echo "Downloading ${#selected[@]} database(s) to $dest from ${DB_SERVER}..."

# Run rclone as the invoking user so files aren't root-owned, and mount the
# destination into the container.
RCLONE_DOCKER_OPTS=(-u "$(id -u):$(id -g)" -v "$dest:/dest")

# Progress display. rclone only repaints its progress line *in place* when its
# stdout is a terminal, so allocate a docker TTY (-t) when we have one and let
# --progress show a single, live-updating status line. With no TTY (output piped
# or redirected to a log) --progress instead dumps one un-erased line per refresh
# — the console spam — so fall back to a periodic one-line stats summary, bumped
# to NOTICE so it isn't swallowed by rclone_sftp's default ERROR log level.
progress_opts=(--progress --stats-one-line)
copy_log_level=""
if [ -t 1 ]; then
  RCLONE_DOCKER_OPTS+=(-t)
else
  progress_opts=(--stats 30s --stats-one-line)
  copy_log_level="NOTICE"
fi

for db in "${selected[@]}"; do
  echo
  echo "=== $db ==="
  # copy is incremental: files already present with a matching size/modtime are
  # skipped, so an interrupted run resumes instead of starting over — only the
  # not-yet-transferred files are fetched.
  if [ -d "$dest/$db" ] && [ -n "$(ls -A "$dest/$db" 2>/dev/null)" ]; then
    echo "Existing data detected — resuming download (already-fetched files are skipped)."
  fi
  RCLONE_LOG_LEVEL="$copy_log_level" rclone_sftp copy "$(db_remote "$db")" "/dest/$db" \
    --transfers "$transfers" "${progress_opts[@]}"
  # Wire the freshly-downloaded folder into the engine config automatically.
  register_output_dir "$db" "$dest/$db" "$ENGINE_CONFIG"
done

echo
echo "All selected databases are in $dest"
echo "Registered them under OUTPUT_DIRECTORIES in $ENGINE_CONFIG"
echo "Restart the stack to pick them up:  cheese stop && cheese start"
