#!/bin/bash

set -e

echo Downloading CHEESE images...
REGISTRY="cheese.azurecr.io"
REPO_NAME="${REGISTRY}/on-prem"

# ── Image channel (develop vs main) ───────────────────────────────────────────
# Mirror the resolution in scripts/_compose-env so `update-images` pulls exactly
# the tags `cheese start` will run. main checkout → :latest, develop (or any
# other branch) → :dev; an explicit CHEESE_IMAGE_TAG wins; non-git → :latest.
# Only the per-branch product images (database/orchestrator/search-ui/
# alignment-service) are channel-tagged — the rest are published as :latest only.
if [ -z "${CHEESE_IMAGE_TAG:-}" ]; then
  _onprem_branch="$(git -C "${REPO_FOLDER:-.}" rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
  case "$_onprem_branch" in
    main|"") CHEESE_IMAGE_TAG="latest"  ;;
    *)       CHEESE_IMAGE_TAG="develop" ;;
  esac
  unset _onprem_branch
fi
echo "Image channel: pulling '${CHEESE_IMAGE_TAG}' tag for product images (database/orchestrator/search-ui/alignment-service)."

# image_tag IMAGE → the tag to pull for that image. Branch-tagged product images
# follow the channel; everything else is :latest.
image_tag() {
  case "$1" in
    cheese-database|cheese-orchestrator|cheese-search-ui|cheese-alignment-service) echo "$CHEESE_IMAGE_TAG" ;;
    *) echo "latest" ;;
  esac
}

# docker login takes a registry hostname, not a repo path. The previous form
# (`docker login ... cheese.azurecr.io/on-prem`) returned UNAUTHORIZED from ACR;
# pulls only kept working because earlier installs had cached creds for the
# bare host. Also use --password-stdin to avoid the insecure-CLI-password warning.
if [ "$CHEESE_CUSTOMER" = 'test' ] ; then
  echo "$CHEESE_PASSWORD" | docker login -u admin --password-stdin "$REGISTRY"
else
  echo "$CHEESE_PASSWORD" | docker login -u "$CHEESE_CUSTOMER" --password-stdin "$REGISTRY"
fi

# Pull the CHEESE app images
echo "Images included in package :" $CHEESE_PACKAGE
echo "To change the package contents please use cheese update-env"
read -p "Do you want to pull the latest images? (y/n)" answer

case "$answer" in
    [Yy]* )
        echo "Pulling the images according to the above package."

        # Canonical pull order — images are always pulled in this sequence
        # regardless of how CHEESE_PACKAGE happens to list them, so the order is
        # deterministic. cheese-database is first because it's also the image
        # that generates the license key (cheese generate-license-key), so it
        # must be available before anything else.
        CHEESE_PULL_ORDER="cheese-database cheese-search-ui cheese-orchestrator cheese-electrostatics-inference cheese-inference cheese-alignment-service"

        # Normalise CHEESE_PACKAGE into a whitespace-trimmed, space-delimited
        # lookup string (",a, b ,c," → " a b c ") for membership tests.
        requested=" "
        IFS=',' read -ra strings <<< "$CHEESE_PACKAGE"
        for s in "${strings[@]}"; do
            s="${s//[[:space:]]/}"
            [ -n "$s" ] && requested="${requested}${s} "
        done

        pull_image() {
            local tag
            tag="$(image_tag "$1")"
            echo "Pulling $REPO_NAME/$1/${CHEESE_CUSTOMER}:${tag}"
            docker pull "$REPO_NAME/$1/${CHEESE_CUSTOMER}:${tag}"
        }

        # 1) Recognised images, in canonical order.
        for image_name in $CHEESE_PULL_ORDER; do
            case "$requested" in *" $image_name "*) pull_image "$image_name" ;; esac
        done

        # 2) Any requested image not in the canonical order — pull it last rather
        #    than silently dropping it.
        for image_name in $requested; do
            case " $CHEESE_PULL_ORDER " in
                *" $image_name "*) : ;;  # already pulled above
                *) echo "⚠️  '$image_name' is not in the known pull order — pulling it last."
                   pull_image "$image_name" ;;
            esac
        done
        ;;
    [Nn]* )
        exit 0
        ;;
    * )
        echo "Invalid response. Please enter y or n."
        ;;
esac


# Pull Nginx and Oauth2-proxy images
if [ $NGINX == "true" ];then
echo "Pulling nginx image..."
docker pull docker.io/library/nginx:alpine
echo "Pulling oauth2 image..."
docker pull quay.io/oauth2-proxy/oauth2-proxy:latest

fi

# Pull the rclone image used by configure-dbs / download-dbs (public Docker Hub,
# no ACR login needed). Non-fatal: a failure here shouldn't abort the run, since
# database download is a separate, optional step.
RCLONE_IMAGE="${RCLONE_IMAGE:-rclone/rclone:latest}"
echo "Pulling rclone image ($RCLONE_IMAGE) for database transfers..."
docker pull "$RCLONE_IMAGE" || echo "⚠️  Could not pull $RCLONE_IMAGE — 'cheese download-dbs' will retry on first use."