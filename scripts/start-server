#!/bin/bash
# Bring up the cheese-orchestrator (CHEESE API). Depends on the database stack
# being healthy — compose enforces this via depends_on: condition: service_healthy.

set -e
source "$(dirname "$(readlink -f "$0")")/_compose-env"

show_help() {
  echo "Usage: cheese start-server [options]"
  echo "Options:"
  echo "  -p, --port PORT   Host port to publish the API on (default: 8001)"
  echo "  -h, --help        Show this help"
  exit 1
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -p|--port)
      export API_HOST_PORT="$2"
      shift 2
      ;;
    -h|--help)
      show_help
      ;;
    # Accept-and-ignore legacy flags (compose uses stable names).
    --db_container|--jobs_db_container|--jobs_exec_container|--download_exec_container|--jobs_file_server_container|--api_container|--file_server_port)
      shift 2
      ;;
    *)
      echo "Unknown option: $1"
      show_help
      ;;
  esac
done

# Pick free host ports automatically if the requested/default ones are taken.
# `up -d api` also starts the db stack (incl. file-server), so adapt all ports.
ensure_all_free_ports

# Compose handles the database deps automatically.
mkdir -p "${JOBS_DATA_PATH:-${HOME}/.local/share/cheese-jobs}"
echo "Starting CHEESE API (compose will start the database stack if it isn't running)..."
$COMPOSE_CMD up -d api

echo "Waiting for cheese-api to be healthy..."
end=$((SECONDS+120))
while [ $SECONDS -lt $end ]; do
  status=$(docker inspect -f '{{.State.Health.Status}}' cheese-api 2>/dev/null || echo "missing")
  if [ "$status" = "healthy" ]; then
    echo "CHEESE API is available at http://${IP:-localhost}:${API_HOST_PORT:-8001}"
    exit 0
  fi
  printf "."
  sleep 3
done

echo
echo "Timeout waiting for cheese-api. Last status: $status"
echo "Check logs: $COMPOSE_CMD logs api"
exit 1
