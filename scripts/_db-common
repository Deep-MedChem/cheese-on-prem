#!/bin/bash
# Shared helpers for the database scripts (configure-dbs, download-dbs).
#
# The indexed databases live on a locked-down, SFTP-only server (chrooted,
# ForceCommand internal-sftp — no shell, so rsync/ssh-exec are impossible). We
# talk to it with rclone's sftp backend, which gives resumable, incremental,
# parallel transfers over plain SFTP. rclone runs from its official Docker image
# (Docker is already a hard dependency of the stack), so nothing extra is
# installed on the host.
#
# Exported / provided to callers:
#   DB_SERVER, DB_SFTP_USER, DB_REMOTE_PATH, RCLONE_IMAGE, DB_CONFIG
#   db_remote [subpath]      → prints the rclone remote spec (:sftp:...)
#   rclone_sftp <args...>    → runs rclone in Docker against the SFTP server
#                              (extra `docker run` opts via the RCLONE_DOCKER_OPTS array)

# ── Server ────────────────────────────────────────────────────────────────────
# No default on purpose: this is a public repo, so the database host is NOT
# committed here. DeepMedChem provides the address on request; set it as
# DB_SERVER in ~/.config/cheese/cheese-env-file.conf (exported by cheese-env.sh)
# or in the environment.
DB_SERVER="${DB_SERVER:-}"
DB_SFTP_USER="${CHEESE_CUSTOMER:-cheese-customer}"
# Directory on the server that holds the database folders. Empty = the SFTP
# landing directory (where a login lands), which is where the DBs are exposed.
# Override by exporting DB_REMOTE_PATH if the layout ever changes.
DB_REMOTE_PATH="${DB_REMOTE_PATH:-}"

# rclone image (Docker Hub). Override RCLONE_IMAGE to pin a version or point at
# an internal mirror.
RCLONE_IMAGE="${RCLONE_IMAGE:-rclone/rclone:latest}"

# Where the database selection lives.
DB_CONFIG="${DB_CONFIG:-${HOME}/.config/cheese/databases.conf}"

# Build an rclone remote spec, optionally for a sub-path under DB_REMOTE_PATH.
db_remote() {
  local sub="$1" p="$DB_REMOTE_PATH"
  [ -n "$sub" ] && p="${p:+$p/}$sub"
  printf ':sftp:%s' "$p"
}

# The SFTP password is its own setting (CHEESE_DB_PASSWORD) — deliberately NOT a
# fallback to CHEESE_PASSWORD, which is the image-registry password and would
# just produce a confusing "ssh: unable to authenticate" failure. Obscured for
# rclone and cached so we only shell out to rclone obscure once.
_db_obscured_pass=""
db_obscured_pass() {
  [ -n "$_db_obscured_pass" ] && { printf '%s' "$_db_obscured_pass"; return 0; }
  _db_obscured_pass=$(docker run --rm "$RCLONE_IMAGE" obscure "$CHEESE_DB_PASSWORD") || return 1
  printf '%s' "$_db_obscured_pass"
}

# Connectivity check: actually connect to the server with the configured
# credentials (a cheap top-level listing) and fail fast if it doesn't work.
# Timeouts/retries are bounded so a bad host or password fails in seconds instead
# of rclone's ~30s+ default backoff. The rclone error is captured and classified
# so the message points at the likely culprit — a rejected login → password, a
# host/DNS/timeout error → server address.
db_ping() {
  echo "Checking connection to ${DB_SFTP_USER}@${DB_SERVER}..."
  local out rc
  out=$(rclone_sftp lsd "$(db_remote)" \
          --contimeout 10s --timeout 20s --low-level-retries 1 --retries 1 2>&1)
  rc=$?
  [ "$rc" -eq 0 ] && { echo "Connected."; return 0; }

  local hint
  if printf '%s' "$out" | grep -qiE 'unable to authenticate|permission denied|auth.*fail|handshake failed'; then
    hint="The server refused the login — CHEESE_DB_PASSWORD is likely wrong."
  elif printf '%s' "$out" | grep -qiE 'no such host|name or service not known|connection refused|no route to host|i/o timeout|timed out|dial tcp|missing address|connection reset'; then
    hint="Could not reach the host — DB_SERVER is likely wrong or unreachable."
  else
    hint="Connection to the database server failed."
  fi

  echo "$hint" >&2
  echo "Fix it by running:  cheese update-env" >&2
  echo "(DB_SERVER and CHEESE_DB_PASSWORD are provided by the DeepMedChem team;" >&2
  echo "CHEESE_DB_PASSWORD is separate from the image-registry password CHEESE_PASSWORD)." >&2
  # One concise line of the underlying rclone error, for debugging.
  local detail
  detail=$(printf '%s\n' "$out" | grep -iE 'CRITICAL|ERROR|Failed|unable|refused|no such host|timeout' | head -1)
  [ -n "$detail" ] && echo "  (rclone: ${detail})" >&2
  return 1
}

# Run rclone in Docker with the SFTP backend pre-configured via env. Pass extra
# `docker run` options (e.g. volume mounts, --user) in the RCLONE_DOCKER_OPTS
# array before calling. rclone's sftp backend skips host-key verification by
# default, so non-interactive runs don't stall on an unknown-host prompt.
RCLONE_DOCKER_OPTS=()
rclone_sftp() {
  local pass
  pass=$(db_obscured_pass) || return 1
  # --log-level ERROR silences rclone's chatty NOTICE/INFO lines (config-not-
  # found, host-key notice, etc.) while still surfacing real ERROR/CRITICAL
  # failures. Override with RCLONE_LOG_LEVEL=NOTICE to debug.
  docker run --rm "${RCLONE_DOCKER_OPTS[@]}" \
    -e RCLONE_SFTP_HOST="$DB_SERVER" \
    -e RCLONE_SFTP_USER="$DB_SFTP_USER" \
    -e RCLONE_SFTP_PASS="$pass" \
    "$RCLONE_IMAGE" --log-level "${RCLONE_LOG_LEVEL:-ERROR}" "$@"
}

# List database directory names (one per line) from the server, or fail with a
# clear message. Distinguishes a connection/auth failure (rclone non-zero) from
# a successful-but-empty listing — callers handle the empty case themselves.
list_db_dirs() {
  local listing
  if ! listing=$(rclone_sftp lsf --dirs-only "$(db_remote)"); then
    echo "Could not list databases on ${DB_SERVER} — check connectivity and that" >&2
    echo "CHEESE_DB_PASSWORD is correct." >&2
    return 1
  fi
  printf '%s\n' "$listing" | sed 's:/*$::; /^[[:space:]]*$/d' | sort
}
