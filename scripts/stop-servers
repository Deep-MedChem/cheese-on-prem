#!/bin/bash
# Stop the cheese-database + cheese-orchestrator stack (preserves UI).
# Use `cheese stop` (stop-main-servers) to bring everything down.

set -e
source "$(dirname "$(readlink -f "$0")")/_compose-env"

echo "Stopping CHEESE backend services..."
$COMPOSE_CMD stop api jobs-db jobs-exec download-exec file-server db
# Also stop the optional inference service (best-effort).
$COMPOSE_CMD stop inference 2>/dev/null || true
echo "Stopped."
