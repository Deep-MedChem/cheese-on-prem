#!/bin/bash
# Discover the databases available on the SFTP server and write a selection
# config that `cheese download-dbs` reads. Re-running refreshes the list while
# preserving any yes/no choices you've already made.
set -e
source "$(dirname "$(readlink -f "$0")")/_db-common"

show_help() {
  echo "Usage: cheese configure-dbs [options]"
  echo "Lists databases available on ${DB_SERVER} and writes the download"
  echo "selection to ${DB_CONFIG}."
  echo "Options:"
  echo "  --no-edit    Just (re)write the config; don't open it in an editor"
  echo "  -h, --help   Show this help message"
  exit 1
}

edit=true
while [[ $# -gt 0 ]]; do
  case "$1" in
    --no-edit) edit=false; shift ;;
    -h|--help) show_help ;;
    *) echo "Unknown option: $1"; show_help ;;
  esac
done

# Verify we can actually reach the server with the configured credentials, and
# fail fast with a targeted message if not.
db_ping || exit 1

# Preserve previously-chosen flags (name -> yes/no) so a refresh doesn't reset
# selections the operator already made.
declare -A prev
if [ -f "$DB_CONFIG" ]; then
  while IFS= read -r line; do
    line="${line%%#*}"
    [[ "$line" =~ ^[[:space:]]*$ ]] && continue
    key="${line%%=*}";  key="${key//[[:space:]]/}"
    val="${line#*=}";   val="${val//[[:space:]]/}"
    [ -n "$key" ] && prev["$key"]="$val"
  done < "$DB_CONFIG"
fi

echo "Listing databases on ${DB_SERVER}..."
listing=$(list_db_dirs) || exit 1
if [ -z "$listing" ]; then
  echo "No databases found at $(db_remote) on ${DB_SERVER}." >&2
  echo "(Set DB_REMOTE_PATH if the layout differs.)" >&2
  exit 1
fi
mapfile -t dbs <<< "$listing"

echo "Found ${#dbs[@]} database(s)."

mkdir -p "$(dirname "$DB_CONFIG")"
tmp="$(mktemp)"
{
  echo "# CHEESE databases available on ${DB_SERVER}"
  echo "# Refreshed: $(date '+%Y-%m-%d %H:%M:%S %z')  (re-run 'cheese configure-dbs' to update)"
  echo "#"
  echo "# Set each flag to yes/no, then run 'cheese download-dbs' (downloads all"
  echo "# selected; with no config it downloads everything)."
  echo "#"
  echo "#   <name>=<yes|no>"
  echo
} > "$tmp"

for db in "${dbs[@]}"; do
  flag="${prev[$db]:-yes}"           # new DBs default to yes (download by default)
  [[ "$flag" == "yes" || "$flag" == "no" ]] || flag="yes"
  printf '%s=%s\n' "$db" "$flag" >> "$tmp"
  echo "  $db  -> $flag"
done

mv "$tmp" "$DB_CONFIG"
echo
echo "Wrote selection to $DB_CONFIG"

if [ "$edit" = true ]; then
  read -r -p "Open it now to adjust which databases to download? [Y/n] " ans
  case "${ans:-Y}" in
    [Nn]*) : ;;
    *) "${EDITOR:-nano}" "$DB_CONFIG" ;;
  esac
fi

echo "Done. Run 'cheese download-dbs --dest <folder>' to fetch the selected databases."
