#!/bin/bash
# Bring up the cheese-database stack (main DB + jobs API + workers + file server).
# Thin wrapper around `docker compose up -d` — see docker-compose.yml.

set -e
source "$(dirname "$(readlink -f "$0")")/_compose-env"

show_help() {
  echo "Usage: cheese start-db [options]"
  echo "Starts the cheese-database stack: db, jobs-db, jobs-exec, download-exec, file-server."
  echo "Options:"
  echo "  --jobs_file_server_port PORT   Host port for the jobs file server (default: 8000)"
  echo "  -h, --help                     Show this help"
  exit 1
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --jobs_file_server_port)
      export JOBS_FILE_SERVER_PORT="$2"
      shift 2
      ;;
    -h|--help)
      show_help
      ;;
    # Accept and ignore legacy --*_container flags (compose uses stable names).
    --db_container|--jobs_db_container|--jobs_exec_container|--download_exec_container|--jobs_file_server_container)
      shift 2
      ;;
    --db_port|--jobs_db_port)
      # No longer separately published; the orchestrator (api) is the public surface.
      shift 2
      ;;
    *)
      echo "Unknown option: $1"
      show_help
      ;;
  esac
done

mkdir -p /tmp/cheese-jobs

echo "Starting cheese-database stack..."
$COMPOSE_CMD up -d db jobs-db jobs-exec download-exec file-server

echo "Waiting for cheese-database to be healthy (this can take up to 3 min on first start)..."
# `docker compose up` returns once containers are created; the readiness wait
# uses the healthcheck defined in docker-compose.yml.
end=$((SECONDS+360))
while [ $SECONDS -lt $end ]; do
  status=$(docker inspect -f '{{.State.Health.Status}}' cheese-db 2>/dev/null || echo "missing")
  if [ "$status" = "healthy" ]; then
    echo "cheese-database is healthy."
    exit 0
  fi
  printf "."
  sleep 5
done

echo
echo "Timeout waiting for cheese-database to become healthy. Last status: $status"
echo "Check logs: $COMPOSE_CMD logs db"
exit 1
