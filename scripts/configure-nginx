#!/bin/bash
source "$(dirname "$(readlink -f "$0")")/_editor"

open_in_editor "${HOME}/.config/cheese/nginx.conf"

while true; do
  read -rp "Do you want to update your SSL certificates? (Y/N): " answer
  case "$answer" in
    [Yy]* )
      echo "Updating certificates..."
      # Put your update command here, for example:
      open_in_editor "${HOME}/.config/cheese/nginx.crt"
      open_in_editor "${HOME}/.config/cheese/nginx.key"
      break
      ;;
    [Nn]* )
      echo "Skipping certificate update."
      break
      ;;
    * )
      echo "Please answer Y or N."
      ;;
  esac
done