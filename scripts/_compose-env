#!/bin/bash
# Sourced by every start-*/stop-* wrapper. Picks the compose project name and
# project file path so `docker compose` invocations work no matter which
# directory the user is in. Also maps the legacy NGINX=true env var to the SSO
# compose profile (off by default).
#
# Exported for use by callers:
#   COMPOSE_CMD  — the `docker compose -p ... -f ...` prefix to invoke
#   IP, UID      — kept available for downstream scripts (legacy env)

# Stable project name so `docker compose ...` from any cwd targets the same
# stack. Mirrors the customer namespace used in image tags.
export COMPOSE_PROJECT_NAME="${COMPOSE_PROJECT_NAME:-cheese}"

# Locate docker-compose.yml: REPO_FOLDER is set by cheese-env.sh on install.
COMPOSE_FILE="${REPO_FOLDER}/docker-compose.yml"
if [ ! -f "$COMPOSE_FILE" ]; then
  echo "docker-compose.yml not found at $COMPOSE_FILE"
  echo "Set REPO_FOLDER in ~/.config/cheese/cheese-env-file.conf to your cheese-on-prem checkout."
  exit 1
fi

# Load the human-readable port map (config/ports.env) so its values feed both
# docker-compose interpolation and ensure_all_free_ports below. A value already
# present in the environment wins (so `API_HOST_PORT=9999 cheese start` and the
# runtime auto-bump both override the file); the file wins over the compose
# `${VAR:-default}` fallbacks, which still keep compose runnable standalone.
PORTS_ENV_FILE="${REPO_FOLDER}/config/ports.env"
if [ -f "$PORTS_ENV_FILE" ]; then
  while IFS= read -r _line; do
    _line="${_line%%#*}"                                  # drop inline comments
    [[ "$_line" =~ ^[[:space:]]*$ ]] && continue          # skip blank/comment-only
    _key="${_line%%=*}"; _key="${_key//[[:space:]]/}"     # trim key
    _val="${_line#*=}"
    _val="${_val#"${_val%%[![:space:]]*}"}"               # trim leading space
    _val="${_val%"${_val##*[![:space:]]}"}"               # trim trailing space
    [ -z "${!_key:-}" ] && export "$_key=$_val"           # shell env wins
  done < "$PORTS_ENV_FILE"
  unset _line _key _val
fi

# Map legacy NGINX=true → SSO profile.
if [ "${NGINX:-false}" = "true" ]; then
  export COMPOSE_PROFILES="sso"
  # In SSO mode, downloads are served through NGINX, not the raw file-server port.
  export JOBS_FILE_SERVER_URL="${JOBS_FILE_SERVER_URL:-https://${IP}/cheese-fileserver}"
fi

# Make UID available for the `user:` field in compose.yml (bash sets UID but
# doesn't export it by default).
export UID

# The cheese-network is declared `external` in compose, so it must pre-exist.
# Create it on demand (idempotent): adopts a legacy network from the old
# docker-run flow if present, otherwise creates a fresh one for new installs.
docker network inspect cheese-network >/dev/null 2>&1 || docker network create cheese-network >/dev/null

# ── Job-data directory guard ──────────────────────────────────────────────────
# The jobs containers and file-server mount JOBS_DATA_PATH; if it's missing the
# file-server's `http.server --directory ...` exits and crash-loops under
# restart: unless-stopped. Check on every startup, warn, and recreate so the
# stack always comes up cleanly. The installer normally writes JOBS_DATA_PATH
# into cheese-env-file.conf, but fall back to the default if it's unset.
DEFAULT_JOBS_DATA_PATH="${HOME}/.local/share/cheese-jobs"
if [ -z "${JOBS_DATA_PATH:-}" ]; then
  echo "⚠️  JOBS_DATA_PATH is not set — falling back to default ${DEFAULT_JOBS_DATA_PATH}" >&2
  export JOBS_DATA_PATH="$DEFAULT_JOBS_DATA_PATH"
fi
if [ ! -d "$JOBS_DATA_PATH" ]; then
  echo "⚠️  Job directory does not exist — recreating it at ${JOBS_DATA_PATH}" >&2
  mkdir -p "$JOBS_DATA_PATH"
fi

# ── Automatic host-port adaptation ────────────────────────────────────────────
# The start-* wrappers call ensure_all_free_ports before `compose up` so a busy
# host port no longer aborts the launch with "port is already allocated" — we pick
# the next free port instead.

# Ports already assigned during this invocation, so two services that scan from
# nearby defaults can't both pick the same not-yet-bound port.
_claimed_ports=" "
_claim_port() { _claimed_ports="${_claimed_ports}$1 "; }

# port_in_use PORT → returns 0 (true) if PORT is already taken: claimed earlier in
# this run, bound by a host listener (ss), or published by a container. The ss +
# docker pair matters because iptables-only docker setups don't surface published
# ports through ss.
port_in_use() {
  local p="$1"
  case "$_claimed_ports" in *" $p "*) return 0 ;; esac
  ss -ltnH "sport = :$p" 2>/dev/null | grep -q . && return 0
  docker ps --format '{{.Ports}}' 2>/dev/null \
    | grep -qE "(0\.0\.0\.0|\[::\]|127\.0\.0\.1):$p->" && return 0
  return 1
}

# ensure_free_port VAR DEFAULT OWN_CONTAINER
# Resolves a usable host port and exports it as VAR:
#   • If OWN_CONTAINER is already running, reuse the port it's published on, so
#     re-running a start script never relocates a live service.
#   • Otherwise take VAR's current value (or DEFAULT); if that port is busy, scan
#     upward for the first free one and announce the change.
ensure_free_port() {
  local var="$1" def="$2" own="$3"

  if [ -n "$own" ]; then
    local running
    running=$(docker ps --filter "name=^${own}$" --format '{{.Ports}}' 2>/dev/null \
      | grep -oE ':[0-9]+->' | grep -oE '[0-9]+' | head -1)
    if [ -n "$running" ]; then
      _claim_port "$running"; export "$var=$running"; return 0
    fi
  fi

  local want="${!var:-$def}" p tries=0
  p="$want"
  while port_in_use "$p"; do
    p=$((p + 1)); tries=$((tries + 1))
    if [ "$tries" -gt 50 ]; then
      echo "⚠️  No free port found near $want for ${own:-$var}; keeping $want." >&2
      _claim_port "$want"; export "$var=$want"; return 0
    fi
  done
  [ "$p" != "$want" ] && echo "⚠️  Port $want is in use — publishing ${own:-$var} on $p instead." >&2
  _claim_port "$p"; export "$var=$p"
}

# ensure_all_free_ports — adapt every published host port up front. Called by the
# start-* wrappers so transitively-started dependencies (e.g. file-server, pulled
# in by `compose up -d api`) get a free port too, not just the directly-named one.
# Services not started by a given wrapper are unaffected: setting their var has no
# effect unless compose actually brings them up.
ensure_all_free_ports() {
  ensure_free_port JOBS_FILE_SERVER_PORT 8000 cheese-file-server
  ensure_free_port API_HOST_PORT         8001 cheese-api
  ensure_free_port UI_HOST_PORT          3001 cheese-ui
  ensure_free_port INFERENCE_HOST_PORT   8005 cheese-inference
  ensure_free_port ALIGNMENT_HOST_PORT   8006 cheese-alignment
}

# clear_stray_cheese_containers — remove containers that squat on our stable
# container_names but belong to a DIFFERENT compose project (or none) — e.g.
# leftovers from the pre-rename "cheese-on-prem" project, or ad-hoc `docker
# run`s. Compose cannot override a name owned by another project, so an `up`
# fails with a name conflict; and `down` only removes our own project's
# containers, so it can't clear them either. Containers that ARE part of our
# project are left untouched, so this is safe to call before `up` and during
# `down` without disturbing a healthy stack. Names are read from the compose
# file, so new services are covered automatically.
clear_stray_cheese_containers() {
  local names c proj
  names=$(grep -E '^[[:space:]]*container_name:' "$COMPOSE_FILE" 2>/dev/null | awk '{print $2}')
  for c in $names; do
    docker container inspect "$c" >/dev/null 2>&1 || continue
    proj=$(docker inspect -f '{{index .Config.Labels "com.docker.compose.project"}}' "$c" 2>/dev/null)
    if [ "$proj" != "$COMPOSE_PROJECT_NAME" ]; then
      echo "Removing stray container '$c' (project '${proj:-none}') to avoid a name conflict..."
      docker rm -f "$c" >/dev/null 2>&1 || true
    fi
  done
}

# Exported for the wrappers:
export COMPOSE_CMD="docker compose -p ${COMPOSE_PROJECT_NAME} -f ${COMPOSE_FILE}"
