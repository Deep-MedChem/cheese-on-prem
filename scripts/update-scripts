#!/bin/bash

# Pull from repo only in usage mode
echo "Pulling from repo $REPO_FOLDER"
cd $REPO_FOLDER
git pull


set -e
# This script moves all bash scripts to $HOME/.local/bin/cheese

cd "${REPO_FOLDER}/scripts"
echo Installing CHEESE scripts...

# On a (re)install, don't clobber already-installed scripts by default; let the
# user opt in to overwriting. Standalone `cheese update-scripts` leaves
# INSTALL_MODE unset and always refreshes.
overwrite_scripts="y"
if [ "$INSTALL_MODE" = "1" ] && [ -n "$(ls -A "$HOME/.local/bin/cheese" 2>/dev/null)" ]; then
    read -p "Existing CHEESE scripts found in $HOME/.local/bin/cheese. Overwrite them (y/N)? " overwrite_scripts || true
fi

if [[ "$overwrite_scripts" =~ ^[Yy]$ ]]; then
    count=0
    for file in *; do
      # Install everything except the *.sh helpers.
      if [[ "$file" != *.sh ]]; then
        cp "$file" "$HOME/.local/bin/cheese/"
        chmod +x "$HOME/.local/bin/cheese/$file"
        count=$((count + 1))
      fi
    done
    echo "Installed $count scripts to $HOME/.local/bin/cheese"
else
    echo "Preserving existing scripts in $HOME/.local/bin/cheese."
fi

cp "${REPO_FOLDER}/install/cheese-env.sh" ${HOME}/.config/cheese
cp "${REPO_FOLDER}/assets/check_database_server.py" ${HOME}/.config/cheese

chmod -R 777 ${HOME}/.config/cheese