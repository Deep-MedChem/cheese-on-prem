# !/bin/bash

FULL_IMAGE_NAME="cheese.azurecr.io/on-prem/cheese-orchestrator/$CHEESE_CUSTOMER"

CONFIG_FILE="${HOME}/.config/cheese/cheese-env-file.conf"

docker run -it -u $UID -v /:/data --entrypoint python --env-file $CONFIG_FILE --rm $FULL_IMAGE_NAME -c "from cheese_orchestrator import verify_cheese_license; verify_cheese_license()"
