#!/bin/bash
# Bring up oauth2-proxy (perimeter SSO via the customer's IdP). Pulls config from
# ~/.config/cheese/oauth2.env — see config/oauth2.env.template (Entra) and
# config/oauth2-okta.env.template (Okta).

set -e
source "$(dirname "$(readlink -f "$0")")/_compose-env"

export COMPOSE_PROFILES="sso"

echo "Starting oauth2-proxy (sso profile)..."
clear_stray_cheese_containers
$COMPOSE_CMD --profile sso up -d oauth2-proxy
echo "oauth2-proxy is up on :4180."
