#!/bin/bash
# Bring up the cheese-search-ui. Depends on cheese-api being healthy.

set -e
source "$(dirname "$(readlink -f "$0")")/_compose-env"

show_help() {
  echo "Usage: cheese start-app [options]"
  echo "Options:"
  echo "  -p, --port PORT       Host port to publish the UI on (default: 3001)"
  echo "  --api_port PORT       Host port the orchestrator is published on (default: 8001)"
  echo "  -h, --help            Show this help"
  exit 1
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -p|--port)
      export UI_HOST_PORT="$2"
      shift 2
      ;;
    --api_port)
      export API_HOST_PORT="$2"
      shift 2
      ;;
    -h|--help)
      show_help
      ;;
    *)
      echo "Unknown option: $1"
      show_help
      ;;
  esac
done

# Pick free host ports automatically if the requested/default ones are taken.
# `up -d ui` starts the api and file-server deps, and VITE_CHEESE_API tracks
# API_HOST_PORT.
ensure_free_port JOBS_FILE_SERVER_PORT 8000 cheese-file-server
ensure_free_port API_HOST_PORT 8001 cheese-api
while [ "${API_HOST_PORT:-8001}" = "${JOBS_FILE_SERVER_PORT:-8000}" ]; do
  API_HOST_PORT=$((API_HOST_PORT + 1))
  while port_in_use "$API_HOST_PORT"; do
    API_HOST_PORT=$((API_HOST_PORT + 1))
  done
  export API_HOST_PORT
  echo "⚠️  API port conflicted with jobs file-server port — publishing cheese-api on ${API_HOST_PORT} instead." >&2
done
ensure_free_port UI_HOST_PORT 3001 cheese-ui

echo "Starting CHEESE UI (compose will pull in the API + DB deps if needed)..."
$COMPOSE_CMD up -d ui

# Best-effort readiness probe; the UI is up almost immediately once the API is.
sleep 3
echo "CHEESE UI is available at http://${IP:-localhost}:${UI_HOST_PORT:-3001}"
