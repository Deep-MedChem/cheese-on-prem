#!/bin/bash
# Bring up the cheese-search-ui. Depends on cheese-api being healthy.

set -e
source "$(dirname "$(readlink -f "$0")")/_compose-env"

show_help() {
  echo "Usage: cheese start-app [options]"
  echo "Options:"
  echo "  -p, --port PORT       Host port to publish the UI on (default: 3001)"
  echo "  --api_port PORT       Host port the orchestrator is published on (default: 8001)"
  echo "  -h, --help            Show this help"
  exit 1
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -p|--port)
      export UI_HOST_PORT="$2"
      shift 2
      ;;
    --api_port)
      export API_HOST_PORT="$2"
      shift 2
      ;;
    -h|--help)
      show_help
      ;;
    *)
      echo "Unknown option: $1"
      show_help
      ;;
  esac
done

echo "Starting CHEESE UI (compose will pull in the API + DB deps if needed)..."
$COMPOSE_CMD up -d ui

# Best-effort readiness probe; the UI is up almost immediately once the API is.
sleep 3
echo "CHEESE UI is available at http://${IP:-localhost}:${UI_HOST_PORT:-3001}"
